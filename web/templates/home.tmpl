{{template "head" .}}
{{template "site_header" .}}
{{if .Notice}}
<div class="notice sakurairo-notice">
	<i class="iconfont icon-notification"></i>
	<div class="notice-content">{{.Notice}}</div>
</div>
{{end}}
<div class="home-intro">
	<p class="home-kicker"><i class="iconfont icon-sakura"></i> Sakurairo Journal</p>
	<h1 class="home-logo-heading">
		<img class="koimoe-home-logo" src="/static/brand/koimoe-logo-hero.png" alt="{{.Site.Name}}">
	</h1>
	<p>{{.Site.Description}}</p>
</div>
<div class="top-feature sakurairo-feature">
	<h1 class="fes-title"><i class="fa fa-paper-plane-o" aria-hidden="true"></i> Featured</h1>
	<div class="feature-content">
		{{range .FeaturedCards}}
		<li><a href="{{.URL}}"><div class="feature-title"><span class="foverlay-bg"></span><span class="foverlay">{{.Title}}</span></div><img src="{{.Image}}" alt="{{.Title}}"></a></li>
		{{end}}
	</div>
</div>
<div id="primary" class="content-area with-sidebar sakurairo-home-layout">
	<main id="main" class="site-main" role="main">
		<h1 class="main-title sakurairo-main-title"><i class="fa fa-bookmark-o" aria-hidden="true"></i> {{.SectionTitle}}</h1>
		{{range .Posts}}{{template "post_card" .}}{{else}}
		<article class="post post-list empty-home-post"><div class="post-entry"><h1 class="entry-title">No posts yet</h1><p>The database is ready. Next we can import WordPress content or create posts in the admin area.</p></div></article>
		{{end}}
		{{template "pagination" .}}
	</main>
	{{template "sidebar" .}}
</div>
{{template "site_footer" .}}
