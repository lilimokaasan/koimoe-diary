<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260606-settings-anchor-soft">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/pages">Pages</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero compact">
		<div>
			<p>Posts</p>
			<h1>Write softly, publish beautifully.</h1>
		</div>
	</section>
	<main class="admin-shell">
		<section class="admin-panel">
			<div class="panel-title">
				<h1>Posts</h1>
				<a class="button primary" href="/admin/posts/new">New Post</a>
			</div>
			{{if .Message}}<div class="admin-alert success">Saved.</div>{{end}}
			<div class="admin-posts-list-region" data-admin-post-list>
				<nav class="post-filter-tabs" aria-label="Post filters">
					<a href="/admin" class="{{if eq .PostStatus ""}}is-active{{end}}"><span>All</span><strong>{{.PostTotal}}</strong></a>
					<a href="/admin?status=published" class="{{if eq .PostStatus "published"}}is-active{{end}}"><span>Published</span><strong>{{.PostPublished}}</strong></a>
					<a href="/admin?status=scheduled" class="{{if eq .PostStatus "scheduled"}}is-active{{end}}"><span>Scheduled</span><strong>{{.PostScheduled}}</strong></a>
					<a href="/admin?status=draft" class="{{if eq .PostStatus "draft"}}is-active{{end}}"><span>Draft</span><strong>{{.PostDraft}}</strong></a>
					<a href="/admin?status=private" class="{{if eq .PostStatus "private"}}is-active{{end}}"><span>Private</span><strong>{{.PostPrivate}}</strong></a>
				</nav>
				<table class="admin-table admin-posts-table" data-admin-post-table>
					<thead><tr><th>Title</th><th>Status</th><th>Category</th><th>Updated</th><th></th></tr></thead>
					<tbody data-admin-post-rows>
						{{range .Posts}}
						<tr>
							<td class="post-title-cell">
								<a href="/admin/posts/{{.ID}}/edit">{{.Title}}</a>
								{{if .IsPinned}}<span class="admin-table-badge">Pinned</span>{{end}}
								<span>{{.Slug}}</span>
							</td>
							<td class="post-status-cell">
								{{if and (eq .Status "published") (isFuture .PublishedAt)}}
								<span class="status scheduled">scheduled</span>
								{{else}}
								<span class="status {{.Status}}">{{.Status}}</span>
								{{end}}
								<span>{{.PublishedAt.Format "2006-01-02 15:04"}}</span>
							</td>
							<td class="post-category-cell">{{.Category.Name}}</td>
							<td class="post-updated-cell">{{since .UpdatedAt}}</td>
							<td class="table-actions post-open-cell">
								{{if and (eq .Status "published") (not (isFuture .PublishedAt))}}
								<a class="table-action-button" href="/post/{{.Slug}}" target="_blank">Open</a>
								{{else}}
								<a class="table-action-button" href="/admin/posts/{{.ID}}/preview" target="_blank">Preview</a>
								{{end}}
							</td>
						</tr>
						{{else}}
						<tr><td colspan="5">No posts yet.</td></tr>
						{{end}}
					</tbody>
				</table>
			</div>
		</section>
	</main>
	<script>
		if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			document.write('<script src="/static/theme/js/smooth-scroll.js?v=20260519-scroll-atmosphere"><\/script>');
		}
	</script>
	<script src="/static/admin.js?v=20260606-settings-anchor-soft"></script>
</body>
</html>
