<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260606-nav-hover-stable">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/pages">Pages</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero compact">
		<div>
			<p>Conversation</p>
			<h1>Keep the comment garden tidy.</h1>
		</div>
	</section>
	<main class="admin-shell">
		<section class="admin-panel">
			<div class="panel-title">
				<h1>Comments</h1>
			</div>
			{{if .Message}}<div class="admin-alert success">Updated.</div>{{end}}
			<nav class="comment-filter-tabs" aria-label="Comment filters">
				<a href="/admin/comments" class="{{if eq .CommentStatus ""}}is-active{{end}}"><span>All</span><strong>{{.CommentTotal}}</strong></a>
				<a href="/admin/comments?status=approved" class="{{if eq .CommentStatus "approved"}}is-active{{end}}"><span>Approved</span><strong>{{.CommentApproved}}</strong></a>
				<a href="/admin/comments?status=hidden" class="{{if eq .CommentStatus "hidden"}}is-active{{end}}"><span>Hidden</span><strong>{{.CommentHidden}}</strong></a>
				<a href="/admin/comments?status=spam" class="{{if eq .CommentStatus "spam"}}is-active{{end}}"><span>Spam</span><strong>{{.CommentSpam}}</strong></a>
			</nav>
			<form id="comment-bulk-form" class="comment-bulk-bar" method="post" action="/admin/comments/bulk">
				<label class="comment-select-all"><input type="checkbox" data-comment-select-all> Select all</label>
				<select name="bulk_action" aria-label="Bulk action">
					<option value="">Bulk action</option>
					<option value="approve">Approve selected</option>
					<option value="hide">Hide selected</option>
					<option value="spam">Move to spam</option>
					<option value="public">Make public</option>
					<option value="private">Make private</option>
					<option value="delete">Delete selected</option>
				</select>
				<button type="submit">Apply</button>
			</form>
			<div class="comment-admin-list">
				{{range .Comments}}
				<article class="comment-admin-card">
					<label class="comment-admin-check"><input form="comment-bulk-form" type="checkbox" name="comment_ids" value="{{.ID}}" data-comment-select-item aria-label="Select comment from {{.Author}}"></label>
					<div class="comment-admin-main">
						<div class="comment-admin-meta">
							<strong>{{.Author}}</strong>
							<span>{{.Email}}</span>
							<span>{{since .CreatedAt}}</span>
							<span class="status {{.Status}}">{{.Status}}</span>
							{{if .ParentAuthor}}<span class="status reply">reply to {{.ParentAuthor}}</span>{{end}}
							{{if .IsPrivate}}<span class="status private">private</span>{{end}}
						</div>
						<p>{{.Content}}</p>
						<a href="/post/{{.PostSlug}}" target="_blank">{{.PostTitle}}</a>
					</div>
					<div class="comment-admin-actions">
						{{if ne .Status "approved"}}
						<form method="post" action="/admin/comments/{{.ID}}/status">
							<input type="hidden" name="status" value="approved">
							<button type="submit">Approve</button>
						</form>
						{{end}}
						{{if ne .Status "hidden"}}
						<form method="post" action="/admin/comments/{{.ID}}/status">
							<input type="hidden" name="status" value="hidden">
							<button type="submit">Hide</button>
						</form>
						{{end}}
						{{if ne .Status "spam"}}
						<form method="post" action="/admin/comments/{{.ID}}/status">
							<input type="hidden" name="status" value="spam">
							<button type="submit">Spam</button>
						</form>
						{{end}}
						{{if .IsPrivate}}
						<form method="post" action="/admin/comments/{{.ID}}/private">
							<input type="hidden" name="is_private" value="0">
							<button type="submit">Make Public</button>
						</form>
						{{else}}
						<form method="post" action="/admin/comments/{{.ID}}/private">
							<input type="hidden" name="is_private" value="1">
							<button type="submit">Make Private</button>
						</form>
						{{end}}
						<form method="post" action="/admin/comments/{{.ID}}/delete" data-confirm-delete="Delete this comment?">
							<button class="danger" type="submit">Delete</button>
						</form>
					</div>
				</article>
				{{else}}
				<p class="empty-state">No comments yet.</p>
				{{end}}
			</div>
		</section>
	</main>
	<script>
		if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			document.write('<script src="/static/theme/js/smooth-scroll.js?v=20260519-scroll-atmosphere"><\/script>');
		}
	</script>
	<script src="/static/admin.js?v=20260606-nav-hover-stable"></script>
</body>
</html>
