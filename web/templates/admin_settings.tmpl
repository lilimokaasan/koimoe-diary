<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260521-user-menu">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/admin"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero compact">
		<div>
			<p>Theme Settings</p>
			<h1>Tune the site's sakura mood.</h1>
		</div>
	</section>
	<main class="admin-shell">
		<form class="admin-panel settings-panel" method="post" enctype="multipart/form-data" action="/admin/settings">
			<div class="panel-title">
				<h1>Site Settings</h1>
				<div class="actions">
					<a class="button" href="/">Preview</a>
					<button class="primary" type="submit">Save</button>
				</div>
			</div>
			{{if .Message}}<div class="admin-alert success">{{if eq .Message "1"}}Saved.{{else}}{{.Message}}{{end}}</div>{{end}}
			{{if .Error}}<div class="admin-alert error">{{.Error}}</div>{{end}}
			<div class="settings-grid">
				<section>
					<label>Site Name<input type="text" name="site_name" value="{{.Settings.Name}}" required></label>
					<label>Description<textarea name="site_description" rows="3" required>{{.Settings.Description}}</textarea></label>
					<label>Profile Name<input type="text" name="site_author" value="{{.Settings.Author}}" required></label>
					<label>Notice<textarea name="site_notice" rows="3">{{.Settings.Notice}}</textarea></label>
					<label>Footer Text<textarea name="footer_text" rows="3">{{.Settings.FooterText}}</textarea></label>
					<label>Footer Credit<input type="text" name="footer_credit" value="{{.Settings.FooterCredit}}" placeholder="A KoiMoe diary shaped with Sakurairo."></label>
					<label>Navigation<textarea class="navigation-input" name="navigation" rows="7" placeholder="Home | /">{{.Navigation}}</textarea></label>
				</section>
				<section>
					<label>Theme Color<input type="text" name="theme_color" value="{{.Settings.ThemeColor}}" placeholder="#fe9600"></label>
					<label>Hero Image<input type="text" name="hero_image" value="{{.Settings.HeroImage}}" placeholder="/static/theme/screenshot.jpg"></label>
					<label>Hero Overlay Opacity<input type="number" name="hero_overlay_opacity" value="{{.Settings.HeroOverlayOpacity}}" min="0" max="1" step="0.05"></label>
					<label>Profile Avatar URL<input type="text" name="site_avatar" value="{{.Settings.Avatar}}" placeholder="/static/theme/content-image/d-1.jpg"></label>
					<label>Upload Profile Avatar<input type="file" name="avatar_upload" accept="image/jpeg,image/png,image/gif,image/webp"></label>
					<label>Default Post Cover<input type="text" name="default_post_cover" value="{{.Settings.DefaultPostCover}}" placeholder="/static/theme/content-image/d-1.jpg"></label>
					<label class="toggle-field">
						<input type="checkbox" name="sakura_effects" value="1" {{if eq .Settings.SakuraEffects "1"}}checked{{end}}>
						<span>Enable subtle sakura petals</span>
					</label>
					<label>Focus Cards<textarea class="navigation-input" name="focus_cards" rows="5" placeholder="Archive | /archives | /static/theme/content-image/d-1.jpg">{{.FocusCards}}</textarea></label>
					<div class="settings-preview">
						<div class="preview-hero" style="background-image:url('{{.Settings.HeroImage}}')"></div>
						<img src="{{.Settings.Avatar}}" alt="{{.Settings.Author}}">
						<strong>{{.Settings.Name}}</strong>
						<span>{{.Settings.Description}}</span>
					</div>
					<div class="mail-status-panel">
						<div>
							<p>Mail System</p>
							<strong>{{if .MailReady}}Enabled{{else}}Not configured{{end}}</strong>
							<span>Host: {{if .Mail.Host}}{{.Mail.Host}}:{{.Mail.Port}}{{else}}Configure SMTP below{{end}}</span>
							<span>Admin: {{if .Mail.AdminEmail}}{{.Mail.AdminEmail}}{{else}}Set an admin mailbox{{end}}</span>
						</div>
						<button type="submit" form="mail-test-form" {{if not .MailReady}}disabled{{end}}>Send test mail</button>
					</div>
				</section>
			</div>
			<section class="settings-section">
				<div class="panel-title slim">
					<h1>Mail System</h1>
					<p>Configure SMTP for comments, test mail, and password verification codes.</p>
				</div>
				<div class="settings-grid">
					<section>
						<label class="toggle-field">
							<input type="checkbox" name="mail_enabled" value="1" {{if .Mail.Enabled}}checked{{end}}>
							<span>Enable mail delivery</span>
						</label>
						<label>SMTP Host<input type="text" name="smtp_host" value="{{.Mail.Host}}" placeholder="smtpdm.aliyun.com"></label>
						<label>SMTP Port<input type="number" name="smtp_port" value="{{.Mail.Port}}" min="1" max="65535" placeholder="465"></label>
						<label>TLS Mode
							<select name="smtp_tls_mode">
								<option value="implicit" {{if eq .Mail.TLSMode "implicit"}}selected{{end}}>implicit SSL/TLS</option>
								<option value="starttls" {{if eq .Mail.TLSMode "starttls"}}selected{{end}}>STARTTLS</option>
								<option value="none" {{if eq .Mail.TLSMode "none"}}selected{{end}}>none</option>
							</select>
						</label>
					</section>
					<section>
						<label>SMTP Username<input type="text" name="smtp_username" value="{{.Mail.Username}}" placeholder="noreply@koimoe.com"></label>
						<label>SMTP Password<input type="password" name="smtp_password" autocomplete="new-password" placeholder="{{if .MailPasswordSet}}Saved. Leave blank to keep it.{{else}}Aliyun SMTP password{{end}}"></label>
						<label>Sender Address<input type="email" name="smtp_from" value="{{.Mail.From}}" placeholder="noreply@koimoe.com"></label>
						<label>Sender Name<input type="text" name="smtp_from_name" value="{{.Mail.FromName}}" placeholder="KoiMoe Diary"></label>
						<label>Admin Mailbox<input type="email" name="mail_admin_email" value="{{.Mail.AdminEmail}}" placeholder="your mailbox for tests and codes"></label>
					</section>
				</div>
			</section>
		</form>
		<form id="mail-test-form" method="post" action="/admin/mail/test"></form>
		<section class="admin-panel password-panel">
			<div class="panel-title">
				<h1>Password</h1>
				<p>Change the admin password after confirming a code sent to the configured admin mailbox.</p>
			</div>
			<div class="password-grid">
				<form method="post" action="/admin/password/code">
					<h2>Email verification</h2>
					<p>The code is sent to {{if .Mail.AdminEmail}}{{.Mail.AdminEmail}}{{else}}MAIL_ADMIN_EMAIL{{end}} and expires in 10 minutes.</p>
					<button type="submit" {{if not .MailReady}}disabled{{end}}>Send verification code</button>
				</form>
				<form method="post" action="/admin/password">
					<h2>Change password</h2>
					<label>Current Password<input type="password" name="current_password" autocomplete="current-password" required></label>
					<label>New Password<input type="password" name="new_password" autocomplete="new-password" minlength="8" required></label>
					<label>Confirm New Password<input type="password" name="confirm_password" autocomplete="new-password" minlength="8" required></label>
					<label>Email Code<input type="text" name="verification_code" inputmode="numeric" autocomplete="one-time-code" maxlength="6" required></label>
					<button class="primary" type="submit" {{if not .MailReady}}disabled{{end}}>Update password</button>
				</form>
			</div>
		</section>
	</main>
	<script src="/static/admin.js?v=20260521-user-menu"></script>
</body>
</html>
