<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260521-hover-nav">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/admin"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero">
		<div>
			<p>Taxonomy</p>
			<h1>Arrange the diary shelves.</h1>
		</div>
	</section>
	<main class="admin-shell taxonomy-shell">
		{{if .Message}}<div class="admin-alert success">Saved.</div>{{end}}
		<section class="admin-panel">
			<div class="panel-title">
				<h1>Categories</h1>
				<a class="button primary" href="/admin/categories/new">New Category</a>
			</div>
			<table class="admin-table">
				<thead><tr><th>Name</th><th>Slug</th><th>Posts</th><th>Cover</th><th>Description</th><th></th></tr></thead>
				<tbody>
					{{range .Categories}}
					<tr>
						<td><a href="/admin/categories/{{.ID}}/edit">{{.Name}}</a></td>
						<td><span>{{.Slug}}</span></td>
						<td>{{.PostCount}}</td>
						<td>{{if .CoverImage}}<span>set</span>{{else}}<span>none</span>{{end}}</td>
						<td>{{.Description}}</td>
						<td class="table-actions">
							<a href="/category/{{.Slug}}" target="_blank" rel="noopener noreferrer">View</a>
							<form method="post" action="/admin/categories/{{.ID}}/delete"><button class="danger" type="submit">Delete</button></form>
						</td>
					</tr>
					{{else}}
					<tr><td colspan="6">No categories yet.</td></tr>
					{{end}}
				</tbody>
			</table>
		</section>
		<section class="admin-panel">
			<div class="panel-title">
				<h1>Tags</h1>
				<a class="button primary" href="/admin/tags/new">New Tag</a>
			</div>
			<table class="admin-table">
				<thead><tr><th>Name</th><th>Slug</th><th>Posts</th><th></th></tr></thead>
				<tbody>
					{{range .Tags}}
					<tr>
						<td><a href="/admin/tags/{{.ID}}/edit">{{.Name}}</a></td>
						<td><span>{{.Slug}}</span></td>
						<td>{{.PostCount}}</td>
						<td class="table-actions">
							<a href="/tag/{{.Slug}}" target="_blank" rel="noopener noreferrer">View</a>
							<form method="post" action="/admin/tags/{{.ID}}/delete"><button class="danger" type="submit">Delete</button></form>
						</td>
					</tr>
					{{else}}
					<tr><td colspan="4">No tags yet.</td></tr>
					{{end}}
				</tbody>
			</table>
		</section>
	</main>
	<script src="/static/admin.js?v=20260521-hover-nav"></script>
</body>
</html>
