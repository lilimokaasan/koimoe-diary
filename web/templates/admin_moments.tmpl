<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="stylesheet" href="/static/admin.css?v=20260519-moments">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/admin">{{.Site.Name}}</a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<a href="/" target="_blank">View Site</a>
			<a class="button" href="/admin/moments/new">New Moment</a>
			<form method="post" action="/admin/logout"><button type="submit">Logout</button></form>
		</nav>
	</header>
	<section class="admin-hero">
		<div>
			<p>Moments</p>
			<h1>Keep the tiny heartbeats.</h1>
		</div>
		<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}">
	</section>
	<main class="admin-shell">
		<section class="admin-panel">
			<div class="panel-title">
				<h1>Moments</h1>
				<a class="button primary" href="/admin/moments/new">New Moment</a>
			</div>
			{{if .Message}}<div class="admin-alert success">Saved.</div>{{end}}
			<table class="admin-table">
				<thead><tr><th>Content</th><th>Author</th><th>Status</th><th>Created</th><th></th></tr></thead>
				<tbody>
					{{range .Moments}}
					<tr>
						<td><a href="/admin/moments/{{.ID}}/edit">{{.Content}}</a></td>
						<td>{{.Author}}</td>
						<td><span class="status {{.Status}}">{{.Status}}</span></td>
						<td>{{.CreatedAt.Format "2006-01-02 15:04"}}</td>
						<td class="table-actions">
							<a href="/moments" target="_blank" rel="noopener noreferrer">View</a>
							<form method="post" action="/admin/moments/{{.ID}}/delete"><button class="danger" type="submit">Delete</button></form>
						</td>
					</tr>
					{{else}}
					<tr><td colspan="5">No moments yet.</td></tr>
					{{end}}
				</tbody>
			</table>
		</section>
	</main>
</body>
</html>
