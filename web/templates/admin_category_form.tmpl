<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="stylesheet" href="/static/admin.css?v=20260519-taxonomy">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/admin">{{.Site.Name}}</a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<a href="/" target="_blank">View Site</a>
			<form method="post" action="/admin/logout"><button type="submit">Logout</button></form>
		</nav>
	</header>
	<section class="admin-hero compact">
		<div>
			<p>{{if .IsNew}}New Category{{else}}Category Editor{{end}}</p>
			<h1>{{if .IsNew}}Make a new shelf.{{else}}Tune this shelf.{{end}}</h1>
		</div>
		<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}">
	</section>
	<main class="admin-shell">
		<form class="admin-panel editor-panel" method="post" action="{{if .IsNew}}/admin/categories{{else}}/admin/categories/{{.Category.ID}}{{end}}">
			<div class="panel-title">
				<h1>{{if .IsNew}}New Category{{else}}Edit Category{{end}}</h1>
				<div class="actions">
					<a class="button" href="/admin/taxonomy">Cancel</a>
					<button class="primary" type="submit">Save</button>
				</div>
			</div>
			{{if .Message}}<div class="admin-alert success">Saved.</div>{{end}}
			{{if .Error}}<div class="admin-alert error">{{.Error}}</div>{{end}}
			<label>Name<input type="text" name="name" value="{{.Category.Name}}" required></label>
			<label>Slug<input type="text" name="slug" value="{{.Category.Slug}}" placeholder="auto-generated from name"></label>
			<label>Description<textarea name="description" rows="5">{{.Category.Description}}</textarea></label>
			<label>Cover Image<input type="text" name="cover_image" value="{{.Category.CoverImage}}" placeholder="/static/theme/content-image/d-1.jpg"></label>
			{{if .Category.CoverImage}}
			<div class="cover-box taxonomy-cover-preview">
				<img src="{{.Category.CoverImage}}" alt="{{.Category.Name}}">
			</div>
			{{end}}
			<p class="form-note">Deleting a category only removes the shelf. Posts inside it stay safe and become uncategorized.</p>
		</form>
	</main>
</body>
</html>
