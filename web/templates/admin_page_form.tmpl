<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260606-post-action-cell">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/pages">Pages</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero compact">
		<div>
			<p>{{if .IsNew}}New Page{{else}}Page Editor{{end}}</p>
			<h1>{{if .IsNew}}Make a quiet little room.{{else}}Refine this corner.{{end}}</h1>
		</div>
	</section>
	<main class="admin-shell">
		<form class="admin-panel editor-panel" method="post" enctype="multipart/form-data" action="{{if .IsNew}}/admin/pages{{else}}/admin/pages/{{.PageContent.ID}}{{end}}">
			<div class="panel-title">
				<h1>{{if .IsNew}}New Page{{else}}Edit Page{{end}}</h1>
				<div class="actions">
					<a class="button" href="/admin/pages">Cancel</a>
					{{if and (not .IsNew) (ne .PageContent.Status "draft")}}<a class="button" href="/page/{{.PageContent.Slug}}" target="_blank" rel="noopener noreferrer">Open</a>{{end}}
					<button class="primary" type="submit">Save</button>
				</div>
			</div>
			{{if .Message}}<div class="admin-alert success">Saved.</div>{{end}}
			{{if .Error}}<div class="admin-alert error">{{.Error}}</div>{{end}}
			<div class="editor-grid">
				<section class="editor-main">
					<label>Title<input type="text" name="title" value="{{.PageContent.Title}}" required></label>
					<label>Slug<input type="text" name="slug" value="{{.PageContent.Slug}}" placeholder="auto-generated from title"></label>
					<label>Excerpt
						<span class="field-with-action">
							<textarea name="excerpt" rows="3">{{.PageContent.Excerpt}}</textarea>
							<button class="soft-tool" type="button" data-generate-excerpt>Use content</button>
						</span>
					</label>
					<label>Content HTML
						<span class="editor-tools">
							<button class="soft-tool" type="button" data-insert-cover>Insert cover image</button>
							<button class="soft-tool" type="button" data-open-media-picker>Choose from media</button>
						</span>
						<textarea class="content-input" name="content_html" rows="18" required>{{.ContentHTML}}</textarea>
					</label>
					<div class="editor-media-picker compact">
						<div>
							<p>Media Library</p>
							<h2>Pick images without leaving the editor.</h2>
						</div>
						<button class="button" type="button" data-open-media-picker>Open Picker</button>
					</div>
					<div class="media-picker-modal" aria-hidden="true">
						<div class="media-picker-dialog" role="dialog" aria-modal="true" aria-label="Media picker">
							<div class="curated-media-heading">
								<div>
									<p>Cover Library</p>
									<h2>Choose a cover image</h2>
								</div>
								<button class="media-picker-close" type="button" data-close-media-picker aria-label="Close media picker"></button>
							</div>
							<div class="editor-media-strip">
								{{range .MediaAssets}}
								<article class="editor-media-item">
									<img src="{{.URL}}" alt="{{.Name}}">
									<div>
										<strong>{{.Name}}</strong>
										<span>{{.SizeLabel}}{{if .Width}} &middot; {{.Width}}x{{.Height}}{{end}}</span>
									</div>
									<div class="editor-media-actions">
										<button type="button" data-use-cover="{{.URL}}">Set cover</button>
										<button type="button" data-insert-media="{{.URL}}" data-media-alt="{{if .AltText}}{{.AltText}}{{else}}{{.Name}}{{end}}">Insert</button>
									</div>
								</article>
								{{else}}
								<p class="empty-state">No uploaded images yet. Use Media to upload images, then come back to insert them into a page.</p>
								{{end}}
							</div>
							<div class="media-picker-footer">
								<a class="button" href="/admin/media" target="_blank" rel="noopener noreferrer">Open Library</a>
							</div>
						</div>
					</div>
				</section>
				<aside class="editor-side">
					<label>Status
						<select name="status">
							<option value="published" {{if eq .PageContent.Status "published"}}selected{{end}}>Published</option>
							<option value="private" {{if eq .PageContent.Status "private"}}selected{{end}}>Private</option>
							<option value="draft" {{if eq .PageContent.Status "draft"}}selected{{end}}>Draft</option>
						</select>
					</label>
					<div class="cover-box">
						<div class="cover-preview {{if .PageContent.CoverImage}}has-image{{end}}" data-cover-preview>
							<img src="{{.PageContent.CoverImage}}" alt="Cover preview">
							<span>No cover selected</span>
						</div>
						<div class="cover-actions">
							<button class="button" type="button" data-open-media-picker>Choose Cover</button>
							<button class="soft-tool" type="button" data-clear-cover>Clear</button>
						</div>
						<label>Cover Image URL<input type="text" name="cover_image" value="{{.PageContent.CoverImage}}" placeholder="/static/curated-sakura-images/originals/fuji-pagoda-sakura-01.jpg"></label>
						<label>Upload Cover<input type="file" name="cover_upload" accept="image/jpeg,image/png,image/gif,image/webp"></label>
						<p>Choose an uploaded image, paste a URL, or upload a new file. Pages use this image for the top cover and social previews.</p>
					</div>
				</aside>
			</div>
		</form>
	</main>
	<script>
		(function () {
			var trigger = document.querySelector("[data-generate-excerpt]");
			var imageTrigger = document.querySelector("[data-insert-cover]");
			var excerpt = document.querySelector("textarea[name='excerpt']");
			var content = document.querySelector("textarea[name='content_html']");
			var cover = document.querySelector("input[name='cover_image']");
			var coverPreview = document.querySelector("[data-cover-preview]");
			var clearCover = document.querySelector("[data-clear-cover]");
			if (!content) return;
			function updateCoverPreview() {
				if (!coverPreview || !cover) return;
				var image = coverPreview.querySelector("img");
				var url = (cover.value || "").trim();
				coverPreview.classList.toggle("has-image", !!url);
				if (image) image.src = url;
			}
			function insertImage(url, altText) {
				if (!url) return;
				var titleInput = document.querySelector("input[name='title']");
				var alt = (altText || (titleInput && titleInput.value) || "Page image").replace(/"/g, "&quot;");
				var snippet = '<figure><img src="' + url + '" alt="' + alt + '"></figure>';
				var start = typeof content.selectionStart === "number" ? content.selectionStart : content.value.length;
				var end = typeof content.selectionEnd === "number" ? content.selectionEnd : start;
				var before = content.value.slice(0, start).replace(/\s*$/, "");
				var after = content.value.slice(end).replace(/^\s*/, "");
				content.value = before + "\n\n" + snippet + "\n\n" + after;
				var cursor = before.length + snippet.length + 4;
				content.focus();
				content.setSelectionRange(cursor, cursor);
			}
			if (trigger && excerpt) trigger.addEventListener("click", function () {
				var holder = document.createElement("div");
				holder.innerHTML = content.value || "";
				var text = (holder.textContent || holder.innerText || "")
					.replace(/\s+/g, " ")
					.trim();
				if (text.length > 128) text = text.slice(0, 128).replace(/[,.!?;:\s]+$/, "") + "...";
				excerpt.value = text;
				excerpt.focus();
			});
			if (imageTrigger && cover) imageTrigger.addEventListener("click", function () {
				var url = (cover.value || "").trim();
				if (!url) {
					cover.focus();
					return;
				}
				insertImage(url);
			});
			updateCoverPreview();
			cover && cover.addEventListener("input", updateCoverPreview);
			cover && cover.addEventListener("change", updateCoverPreview);
			document.querySelectorAll("[data-use-cover]").forEach(function (button) {
				button.addEventListener("click", function () {
					if (!cover) return;
					cover.value = button.getAttribute("data-use-cover") || "";
					cover.focus();
					updateCoverPreview();
				});
			});
			if (clearCover && cover) clearCover.addEventListener("click", function () {
				cover.value = "";
				updateCoverPreview();
			});
			document.querySelectorAll("[data-insert-media]").forEach(function (button) {
				button.addEventListener("click", function () {
					insertImage(button.getAttribute("data-insert-media") || "", button.getAttribute("data-media-alt") || "");
				});
			});
		})();
	</script>
	<script>
		if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			document.write('<script src="/static/theme/js/smooth-scroll.js?v=20260519-scroll-atmosphere"><\/script>');
		}
	</script>
	<script src="/static/admin.js?v=20260606-post-action-cell"></script>
</body>
</html>
