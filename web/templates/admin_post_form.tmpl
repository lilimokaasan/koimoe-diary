<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260606-settings-anchor-ease">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/pages">Pages</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero compact">
		<div>
			<p>{{if .IsNew}}New Draft{{else}}Editor{{end}}</p>
			<h1>{{if .IsNew}}Catch a new thought.{{else}}Shape this post.{{end}}</h1>
		</div>
	</section>
	<main class="admin-shell">
		<form class="admin-panel editor-panel" method="post" enctype="multipart/form-data" action="{{if .IsNew}}/admin/posts{{else}}/admin/posts/{{.Post.ID}}{{end}}" data-enhanced-editor>
			<div class="panel-title">
				<h1>{{if .IsNew}}New Post{{else}}Edit Post{{end}}</h1>
				<div class="actions">
					<a class="button" href="/admin">Cancel</a>
					{{if not .IsNew}}<a class="button" href="/admin/posts/{{.Post.ID}}/preview" target="_blank" rel="noopener noreferrer">Preview</a>{{end}}
					<button class="button" type="button" data-save-draft>Save Draft</button>
					<button class="primary" type="submit">Save</button>
				</div>
			</div>
			{{if .Message}}<div class="admin-alert success">Saved.</div>{{end}}
			{{if .Error}}<div class="admin-alert error">{{.Error}}</div>{{end}}
			<div class="editor-grid">
				<section class="editor-main">
					<label>Title<input type="text" name="title" value="{{.Post.Title}}" required></label>
					<label>Slug<input type="text" name="slug" value="{{.Post.Slug}}" placeholder="auto-generated from title"></label>
					<label>Excerpt
						<span class="field-with-action">
							<textarea name="excerpt" rows="3">{{.Post.Excerpt}}</textarea>
							<button class="soft-tool" type="button" data-generate-excerpt>Use content</button>
						</span>
					</label>
					<label>Content HTML
						<span class="editor-tools">
							<button class="soft-tool" type="button" data-editor-snippet="heading">Heading</button>
							<button class="soft-tool" type="button" data-editor-snippet="quote">Quote</button>
							<button class="soft-tool" type="button" data-editor-snippet="code">Code</button>
							<button class="soft-tool" type="button" data-editor-snippet="divider">Divider</button>
							<button class="soft-tool" type="button" data-insert-cover>Insert cover image</button>
							<button class="soft-tool" type="button" data-open-media-picker>Choose from media</button>
						</span>
						<textarea class="content-input" name="content_html" rows="18" required>{{.ContentHTML}}</textarea>
						<span class="editor-statusline">
							<span data-editor-count>0 chars · 0 words</span>
							<span data-editor-autosave>Local draft ready.</span>
						</span>
					</label>
					<div class="editor-media-picker compact">
						<div>
							<p>Media Library</p>
							<h2>Pick images without leaving the editor.</h2>
						</div>
						<button class="button" type="button" data-open-media-picker>Open Picker</button>
					</div>
					<div class="media-picker-modal" aria-hidden="true">
						<div class="media-picker-dialog" role="dialog" aria-modal="true" aria-label="Media picker">
							<div class="curated-media-heading">
								<div>
									<p>Cover Library</p>
									<h2>Choose a cover image</h2>
								</div>
								<button class="media-picker-close" type="button" data-close-media-picker aria-label="Close media picker"></button>
							</div>
							<div class="editor-media-strip">
								{{range .MediaAssets}}
								<article class="editor-media-item">
									<img src="{{.URL}}" alt="{{.Name}}">
									<div>
										<strong>{{.Name}}</strong>
										<span>{{.SizeLabel}}{{if .Width}} &middot; {{.Width}}x{{.Height}}{{end}}</span>
									</div>
									<div class="editor-media-actions">
										<button type="button" data-use-cover="{{.URL}}">Set cover</button>
										<button type="button" data-insert-media="{{.URL}}" data-media-alt="{{if .AltText}}{{.AltText}}{{else}}{{.Name}}{{end}}">Insert</button>
									</div>
								</article>
								{{else}}
								<p class="empty-state">No uploaded images yet. Use Media to upload images, then come back to insert them into a post.</p>
								{{end}}
							</div>
							<div class="media-picker-footer">
								<a class="button" href="/admin/media" target="_blank" rel="noopener noreferrer">Open Library</a>
							</div>
						</div>
					</div>
				</section>
				<aside class="editor-side">
					<label>Status
						<select name="status">
							<option value="published" {{if eq .Post.Status "published"}}selected{{end}}>Published</option>
							<option value="private" {{if eq .Post.Status "private"}}selected{{end}}>Private</option>
							<option value="draft" {{if eq .Post.Status "draft"}}selected{{end}}>Draft</option>
						</select>
					</label>
					<label>Publish At
						<input type="datetime-local" name="published_at" value="{{datetimeLocal .Post.PublishedAt}}">
					</label>
					<p class="editor-side-note">Future published posts stay hidden until this time.</p>
					<label class="editor-toggle">
						<input type="checkbox" name="is_pinned" value="1" {{if .Post.IsPinned}}checked{{end}}>
						<span>Pin to top</span>
					</label>
					<label>Category<input type="text" name="category" value="{{.Post.Category.Name}}" placeholder="Blog"></label>
					<label>Tags<input type="text" name="tags" value="{{.PostTags}}" placeholder="Go, Sakurairo"></label>
					<div class="publish-checklist" data-publish-checklist>
						<div class="publish-checklist-head">
							<p>Publish Check</p>
							<strong data-publish-check-summary>Ready when the little details are in place.</strong>
						</div>
						<ul data-publish-check-items></ul>
					</div>
					<div class="cover-box">
						<div class="cover-preview {{if .Post.CoverImage}}has-image{{end}}" data-cover-preview>
							<img src="{{.Post.CoverImage}}" alt="Cover preview">
							<span>No cover selected</span>
						</div>
						<div class="cover-actions">
							<button class="button" type="button" data-open-media-picker>Choose Cover</button>
							<button class="soft-tool" type="button" data-clear-cover>Clear</button>
						</div>
						<label>Cover Image URL<input type="text" name="cover_image" value="{{.Post.CoverImage}}" placeholder="/static/curated-sakura-images/originals/fuji-pagoda-sakura-01.jpg"></label>
						<label>Upload Cover<input type="file" name="cover_upload" accept="image/jpeg,image/png,image/gif,image/webp"></label>
						<p>Choose an uploaded image, paste a URL, or upload a new file. Uploading a file will replace the cover path when saved.</p>
					</div>
				</aside>
			</div>
		</form>
	</main>
	<script>
		(function () {
			var form = document.querySelector("[data-enhanced-editor]");
			var trigger = document.querySelector("[data-generate-excerpt]");
			var imageTrigger = document.querySelector("[data-insert-cover]");
			var excerpt = document.querySelector("textarea[name='excerpt']");
			var content = document.querySelector("textarea[name='content_html']");
			var cover = document.querySelector("input[name='cover_image']");
			var title = document.querySelector("input[name='title']");
			var slug = document.querySelector("input[name='slug']");
			var status = document.querySelector("select[name='status']");
			var category = document.querySelector("input[name='category']");
			var tags = document.querySelector("input[name='tags']");
			var saveDraft = document.querySelector("[data-save-draft]");
			var count = document.querySelector("[data-editor-count]");
			var autosave = document.querySelector("[data-editor-autosave]");
			var checkSummary = document.querySelector("[data-publish-check-summary]");
			var checkItems = document.querySelector("[data-publish-check-items]");
			var coverPreview = document.querySelector("[data-cover-preview]");
			var clearCover = document.querySelector("[data-clear-cover]");
			var autosaveTimer;
			var initialSnapshot = "";
			if (!content) return;
			var draftKey = "koimoe-post-draft:" + (form && form.getAttribute("action") || location.pathname);
			var snippetMap = {
				heading: "<h2>Section title</h2>\n<p>Write softly here.</p>",
				quote: "<blockquote>\n<p>A small thought worth keeping.</p>\n</blockquote>",
				code: "<pre><code>code here</code></pre>",
				divider: "<hr>"
			};
			function snapshot() {
				return JSON.stringify({
					title: title && title.value || "",
					slug: slug && slug.value || "",
					excerpt: excerpt && excerpt.value || "",
					content: content && content.value || "",
					cover: cover && cover.value || "",
					status: status && status.value || "",
					category: category && category.value || "",
					tags: tags && tags.value || ""
				});
			}
			function setAutosaveText(text) {
				if (autosave) autosave.textContent = text;
			}
			function updateCount() {
				if (!count) return;
				var holder = document.createElement("div");
				holder.innerHTML = content.value || "";
				var text = (holder.textContent || holder.innerText || "").replace(/\s+/g, " ").trim();
				var chars = text ? Array.from(text).length : 0;
				var words = text ? text.split(/\s+/).filter(Boolean).length : 0;
				count.textContent = chars + " chars · " + words + " words";
			}
			function contentText() {
				var holder = document.createElement("div");
				holder.innerHTML = content.value || "";
				return (holder.textContent || holder.innerText || "").replace(/\s+/g, " ").trim();
			}
			function publishIssues() {
				var text = contentText();
				var issues = [];
				if (!title || !title.value.trim()) issues.push("Add a title.");
				if (!slug || !slug.value.trim()) issues.push("Confirm the slug.");
				if (text.length < 120) issues.push("Write at least 120 characters of readable content.");
				if (!excerpt || !excerpt.value.trim()) issues.push("Add an excerpt for cards and metadata.");
				if (!cover || !cover.value.trim()) issues.push("Choose a cover image.");
				if (!category || !category.value.trim()) issues.push("Choose a category.");
				if (!tags || !tags.value.trim()) issues.push("Add one or two tags.");
				return issues;
			}
			function updatePublishChecklist() {
				if (!checkItems || !checkSummary) return;
				var issues = publishIssues();
				checkItems.innerHTML = "";
				if (status && status.value !== "published") {
					checkSummary.textContent = "Drafts can stay loose until publishing.";
				} else if (!issues.length) {
					checkSummary.textContent = "Ready to publish.";
				} else {
					checkSummary.textContent = issues.length + " item" + (issues.length === 1 ? "" : "s") + " to check before publishing.";
				}
				issues.forEach(function (issue) {
					var item = document.createElement("li");
					item.textContent = issue;
					checkItems.appendChild(item);
				});
				if (!issues.length) {
					var item = document.createElement("li");
					item.className = "is-ok";
					item.textContent = "Title, slug, excerpt, cover, category, tags, and readable content look set.";
					checkItems.appendChild(item);
				}
			}
			function updateCoverPreview() {
				if (!coverPreview || !cover) return;
				var image = coverPreview.querySelector("img");
				var url = (cover.value || "").trim();
				coverPreview.classList.toggle("has-image", !!url);
				if (image) image.src = url;
			}

			function scheduleAutosave() {
				window.clearTimeout(autosaveTimer);
				autosaveTimer = window.setTimeout(function () {
					try {
						localStorage.setItem(draftKey, snapshot());
						setAutosaveText("Local draft saved.");
					} catch (error) {
						setAutosaveText("Local draft unavailable.");
					}
				}, 500);
			}
			function insertAtCursor(snippet) {
				var start = typeof content.selectionStart === "number" ? content.selectionStart : content.value.length;
				var end = typeof content.selectionEnd === "number" ? content.selectionEnd : start;
				var before = content.value.slice(0, start).replace(/\s*$/, "");
				var after = content.value.slice(end).replace(/^\s*/, "");
				content.value = before + "\n\n" + snippet + "\n\n" + after;
				var cursor = before.length + snippet.length + 4;
				content.focus();
				content.setSelectionRange(cursor, cursor);
				content.dispatchEvent(new Event("input", { bubbles: true }));
			}
			function slugify(value) {
				return (value || "")
					.toLowerCase()
					.trim()
					.replace(/['"]/g, "")
					.replace(/[^a-z0-9]+/g, "-")
					.replace(/^-+|-+$/g, "")
					.slice(0, 120);
			}
			function insertImage(url, altText) {
				if (!url) return;
				var titleInput = document.querySelector("input[name='title']");
				var alt = (altText || (titleInput && titleInput.value) || "Post image").replace(/"/g, "&quot;");
				var snippet = '<figure><img src="' + url + '" alt="' + alt + '"></figure>';
				insertAtCursor(snippet);
			}
			try {
				var saved = JSON.parse(localStorage.getItem(draftKey) || "null");
				if (saved && saved.content && saved.content !== content.value && confirm("Restore the local draft for this post?")) {
					if (title && saved.title) title.value = saved.title;
					if (slug && saved.slug) slug.value = saved.slug;
					if (excerpt && saved.excerpt) excerpt.value = saved.excerpt;
					if (cover && saved.cover) cover.value = saved.cover;
					if (status && saved.status) status.value = saved.status;
					if (category && saved.category) category.value = saved.category;
					if (tags && saved.tags) tags.value = saved.tags;
					content.value = saved.content;
					setAutosaveText("Local draft restored.");
				}
			} catch (error) {
				setAutosaveText("Local draft unavailable.");
			}
			initialSnapshot = snapshot();
			updateCount();
			updateCoverPreview();
			updatePublishChecklist();
			title && title.addEventListener("input", function () {
				if (slug && !slug.value.trim()) slug.value = slugify(title.value);
				scheduleAutosave();
				updatePublishChecklist();
			});
			content.addEventListener("input", function () {
				updateCount();
				scheduleAutosave();
				updatePublishChecklist();
			});
			[slug, excerpt, cover, status, category, tags].forEach(function (field) {
				field && field.addEventListener("input", scheduleAutosave);
				field && field.addEventListener("change", scheduleAutosave);
				field && field.addEventListener("input", updatePublishChecklist);
				field && field.addEventListener("change", updatePublishChecklist);
			});
			cover && cover.addEventListener("input", updateCoverPreview);
			cover && cover.addEventListener("change", updateCoverPreview);
			document.querySelectorAll("[data-editor-snippet]").forEach(function (button) {
				button.addEventListener("click", function () {
					insertAtCursor(snippetMap[button.getAttribute("data-editor-snippet")] || "");
				});
			});
			saveDraft && saveDraft.addEventListener("click", function () {
				if (status) status.value = "draft";
				if (form && form.requestSubmit) {
					form.requestSubmit();
				} else if (form) {
					form.submit();
				}
			});
			window.addEventListener("beforeunload", function (event) {
				if (snapshot() === initialSnapshot) return;
				event.preventDefault();
				event.returnValue = "";
			});
			form && form.addEventListener("submit", function (event) {
				var issues = publishIssues();
				if (status && status.value === "published" && issues.length && !window.confirm("Publish with " + issues.length + " checklist item" + (issues.length === 1 ? "" : "s") + " still open?")) {
					event.preventDefault();
					return;
				}
				initialSnapshot = snapshot();
				try { localStorage.removeItem(draftKey); } catch (error) {}
			});
			if (trigger && excerpt) trigger.addEventListener("click", function () {
				var holder = document.createElement("div");
				holder.innerHTML = content.value || "";
				var text = (holder.textContent || holder.innerText || "")
					.replace(/\s+/g, " ")
					.trim();
				if (text.length > 128) text = text.slice(0, 128).replace(/[,.!?;:\s]+$/, "") + "...";
				excerpt.value = text;
				excerpt.focus();
				updatePublishChecklist();
			});
			if (imageTrigger && cover) imageTrigger.addEventListener("click", function () {
				var url = (cover.value || "").trim();
				if (!url) {
					cover.focus();
					return;
				}
				insertImage(url);
			});
			document.querySelectorAll("[data-use-cover]").forEach(function (button) {
				button.addEventListener("click", function () {
					if (!cover) return;
					cover.value = button.getAttribute("data-use-cover") || "";
					cover.focus();
					updateCoverPreview();
					updatePublishChecklist();
				});
			});
			if (clearCover && cover) clearCover.addEventListener("click", function () {
				cover.value = "";
				updateCoverPreview();
				updatePublishChecklist();
				scheduleAutosave();
			});
			document.querySelectorAll("[data-insert-media]").forEach(function (button) {
				button.addEventListener("click", function () {
					insertImage(button.getAttribute("data-insert-media") || "", button.getAttribute("data-media-alt") || "");
				});
			});
		})();
	</script>
	<script>
		if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			document.write('<script src="/static/theme/js/smooth-scroll.js?v=20260519-scroll-atmosphere"><\/script>');
		}
	</script>
	<script src="/static/admin.js?v=20260606-settings-anchor-ease"></script>
</body>
</html>
