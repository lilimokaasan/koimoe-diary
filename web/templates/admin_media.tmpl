<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{.Title}}</title>
	<link rel="icon" href="/favicon.png?v=20260518-transparent" type="image/png">
	<link rel="shortcut icon" href="/favicon.ico?v=20260518-transparent">
	<link rel="stylesheet" href="/static/admin.css?v=20260609-admin-page-fade">
</head>
<body class="admin-page">
	<header class="admin-topbar">
		<a class="brand" href="/"><img src="/static/brand/koimoe-logo-header.png" alt="{{.Site.Name}}"></a>
		<nav>
			<a href="/admin">Posts</a>
			<a href="/admin/pages">Pages</a>
			<a href="/admin/comments">Comments</a>
			<a href="/admin/links">Links</a>
			<a href="/admin/moments">Moments</a>
			<a href="/admin/media">Media</a>
			<a href="/admin/taxonomy">Taxonomy</a>
			<a href="/admin/settings">Settings</a>
			<div class="admin-sidebar-site">
				<p>{{.Site.Description}}</p>
				<a href="/" target="_blank">View Site</a>
			</div>
		</nav>
	</header>
	<section class="admin-globalbar" aria-label="Admin tools">
		<form class="admin-global-search" action="/search" method="get" target="_blank">
			<input type="search" name="q" placeholder="Search posts, pages..." aria-label="Search site">
			<button type="submit" aria-label="Search"></button>
		</form>
		<div class="admin-global-actions">
			<a class="admin-tool-icon admin-tool-comments" href="/admin/comments" aria-label="Comments"></a>
			<a class="admin-tool-icon admin-tool-settings" href="/admin/settings" aria-label="Settings"></a>
			<div class="admin-user-menu">
				<button class="admin-user-chip" type="button" aria-label="Account menu" aria-expanded="false">
					<img src="{{.Site.Avatar}}" alt="{{.Site.Author}}"><span>{{.Site.Author}}</span>
				</button>
				<div class="admin-user-dropdown" role="menu">
					<a href="/admin/settings" role="menuitem">Profile</a>
					<a href="/admin/settings" role="menuitem">Settings</a>
					<form method="post" action="/admin/logout" role="none"><button type="submit" role="menuitem">Logout</button></form>
				</div>
			</div>
		</div>
	</section>
	<section class="admin-hero compact">
		<div>
			<p>Media Library</p>
			<h1>Keep the image shelf tidy.</h1>
		</div>
	</section>
	<main class="admin-shell">
		<section class="admin-panel">
			<div class="panel-title">
				<h1>Media</h1>
			</div>
			{{if .Message}}<div class="admin-alert success">{{if eq .Message "deleted"}}Deleted.{{else if eq .Message "saved"}}Saved.{{else}}Uploaded.{{end}}</div>{{end}}
			{{if .Error}}<div class="admin-alert error">{{.Error}}</div>{{end}}
			<div class="media-tools-panel">
				<form class="media-upload-panel" method="post" enctype="multipart/form-data" action="/admin/media">
					<label>Upload Image<input type="file" name="media_upload" accept="image/jpeg,image/png,image/gif,image/webp" required></label>
					<button class="primary" type="submit">Upload</button>
				</form>
				<form class="media-filter-panel" method="get" action="/admin/media">
					<label>Search Assets<input type="search" name="q" value="{{.MediaQuery}}" placeholder="Title, alt text, filename, URL..."></label>
					<button type="submit">Filter</button>
					{{if .MediaQuery}}<a class="button" href="/admin/media">Clear</a>{{end}}
				</form>
			</div>
			<div class="curated-media-panel">
				<div class="curated-media-heading">
					<div>
						<p>Uploaded Assets</p>
						<h2>Recent Images</h2>
					</div>
					<span class="media-count">{{len .MediaAssets}} files</span>
				</div>
				<form id="media-bulk-form" class="media-bulk-bar" method="post" action="/admin/media/bulk">
					<select name="bulk_action" aria-label="Bulk action">
						<option value="">Bulk action</option>
						<option value="delete">Delete selected</option>
					</select>
					<button class="bulk-apply-button" type="submit">Apply</button>
				</form>
				<label class="media-select-all media-list-select-all"><input type="checkbox" data-media-select-all> Select all</label>
				<div class="curated-media-grid">
					{{range .MediaAssets}}
					<article class="curated-media-card">
						<label class="media-card-check"><input form="media-bulk-form" type="checkbox" name="media_ids" value="{{.ID}}" data-media-select-item aria-label="Select {{.Name}}"></label>
						<img src="{{.URL}}" alt="{{.Name}}">
						<div>
							<strong>{{.Name}}</strong>
							<span>{{.SizeLabel}}{{if .Width}} &middot; {{.Width}}x{{.Height}}{{end}} &middot; {{.UpdatedAt.Format "2006-01-02 15:04"}}</span>
							<input class="media-url-input" type="text" value="{{.URL}}" readonly>
						</div>
						<form class="media-detail-form" method="post" action="/admin/media/{{.ID}}/update">
							<label>Title<input type="text" name="title" value="{{.Title}}" placeholder="{{.OriginalName}}"></label>
							<label>Alt Text<input type="text" name="alt_text" value="{{.AltText}}" placeholder="Describe the image for readers"></label>
							<label>Description<textarea name="description" rows="2" placeholder="Optional note for future you">{{.Description}}</textarea></label>
							<button type="submit">Save Details</button>
						</form>
						<div class="curated-media-actions">
							<a class="button" href="{{.URL}}" target="_blank" rel="noopener noreferrer">Open</a>
							<button type="button" data-copy-media="{{.URL}}">Copy URL</button>
							<form method="post" action="/admin/media/{{.ID}}/delete" data-confirm-delete="Delete this asset and its uploaded file?">
								<button class="danger" type="submit">Delete</button>
							</form>
						</div>
					</article>
					{{else}}
					<p class="empty-state">No uploaded images yet. Upload one here, then use its URL in posts, profile avatar, covers, or Focus Cards.</p>
					{{end}}
				</div>
			</div>
		</section>
	</main>
	<script>
		document.querySelectorAll("[data-copy-media]").forEach(function (button) {
			button.addEventListener("click", function () {
				var url = button.getAttribute("data-copy-media");
				if (!url || !navigator.clipboard) return;
				navigator.clipboard.writeText(url).then(function () {
					button.textContent = "Copied";
					window.setTimeout(function () {
						button.textContent = "Copy URL";
					}, 1200);
				});
			});
		});
	</script>
	<script>
		if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			document.write('<script src="/static/theme/js/smooth-scroll.js?v=20260519-scroll-atmosphere"><\/script>');
		}
	</script>
	<script src="/static/admin.js?v=20260606-datetime-loop-fix"></script>
</body>
</html>
